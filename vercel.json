{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!sitemap.xml|sitemap-news.xml|robots.txt|ads.txt|favicon|assets|api|googlec2dbc31ac222183d.html).*)",
      "destination": "/index.html"
    }
  ],
  "github": { "silent": true }
}